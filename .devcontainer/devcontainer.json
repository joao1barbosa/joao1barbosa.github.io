{
    "name": "Portfolio Monorepo",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "esbenp.prettier-vscode",
                "dbaeumer.vscode-eslint",
                "ritwickdey.liveserver",
                "syler.sass-indented" 
            ]
        }
    },
    "forwardPorts": [
        3000,
        5500
    ],
    "postCreateCommand": "yarn install --frozen-lockfile"
}